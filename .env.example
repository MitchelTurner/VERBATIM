# PostgreSQL connection string
DATABASE_URL=postgresql://ytdb:ytdb@localhost:5432/ytdb

# Server bind settings (used by Docker/cloud deploys)
HOST=0.0.0.0
PORT=8000

# Cloud PostgreSQL SSL (Render, Railway, Neon, etc.)
# DB_SSLMODE=require

# Startup retry settings
# DB_INIT_RETRIES=30
# DB_INIT_RETRY_DELAY=2

# Optional: YouTube Data API key for richer channel metadata
# YOUTUBE_API_KEY=
