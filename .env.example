# PostgreSQL connection string
DATABASE_URL=postgresql://ytdb:ytdb@localhost:5432/ytdb

# Server bind settings (used by Docker/cloud deploys)
HOST=0.0.0.0
PORT=8000

# Cloud PostgreSQL SSL (Render, Railway, Neon, etc.)
# DB_SSLMODE=require

# Startup retry settings
# DB_INIT_RETRIES=30
# DB_INIT_RETRY_DELAY=2

# Optional: YouTube Data API key for richer channel metadata
# YOUTUBE_API_KEY=

# Caption downloads from cloud IPs (Railway, Render, AWS, etc.) are blocked by
# YouTube. Use a rotating residential proxy — Webshare is the path recommended
# by youtube-transcript-api. Buy a "Residential" package (not "Proxy Server" /
# "Static Residential"), then paste Proxy Username + Password from
# https://dashboard.webshare.io/proxy/settings
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=

# Or any generic HTTP(S)/SOCKS proxy URL instead of Webshare:
# YOUTUBE_HTTP_PROXY=http://user:pass@host:port
# YOUTUBE_HTTPS_PROXY=http://user:pass@host:port

# Pace caption downloads to avoid YouTube HTTP 429 rate limits through the proxy.
# Delay (seconds) between videos; retries with exponential backoff + IP rotation on 429.
# YOUTUBE_CAPTION_DELAY=5
# YOUTUBE_CAPTION_MAX_RETRIES=5
